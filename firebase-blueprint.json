{
  "collections": {
    "reviews": {
      "description": "Real-time dynamic reviews left by clients/users for Dimsum Embege.",
      "schema": {
        "id": "string",
        "name": "string",
        "age": "number",
        "role": "string",
        "rating": "number",
        "text": "string",
        "avatar": "string",
        "createdAt": "timestamp"
      },
      "rules": {
        "read": "true",
        "create": "true",
        "update": "true",
        "delete": "true"
      }
    },
    "products": {
      "description": "Premium Dimsum Embege items, customizable or standard.",
      "schema": {
        "id": "string",
        "name": "string",
        "price": "number",
        "description": "string",
        "image": "string",
        "status": "string",
        "isCustomizable": "boolean",
        "createdAt": "timestamp"
      },
      "rules": {
        "read": "true",
        "create": "true",
        "update": "true",
        "delete": "true"
      }
